# ============================================================
# AP Process Discovery Agent — Environment Variables (EXAMPLE)
# Copy this file to backend/.env and fill in real values.
# NEVER commit your real .env file — it is already in .gitignore.
# ============================================================

# ── Google Gemini (REQUIRED) ────────────────────────────────
# Used for transcription, structuring, scoring, summaries, BPMN,
# PDD/SDD generation, TTS, and the live voice chat (Live API).
GEMINI_API_KEY=your_gemini_api_key_here

# ── MongoDB (REQUIRED) ──────────────────────────────────────
# Stores users, assessments, documents, and live-chat sessions.
MONGODB_URI=your_mongodb_uri_here

# ── Upload limits ───────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100

# ── JWT Auth (REQUIRED) ─────────────────────────────────────
JWT_SECRET=super-secret-key-for-auth

# ── Redis (REQUIRED for OTP / forgot-password) ──────────────
REDIS_URL=redis://localhost:6379

# ── SMTP Email (REQUIRED for forgot-password OTP emails) ────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── Google OAuth (OPTIONAL — enables "Continue with Google") ─
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ── CORS / Frontend (OPTIONAL — for production deployments) ──
# Comma-separated list of allowed origins. Defaults to localhost dev ports.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# FRONTEND_URL=https://your-frontend-domain.com

# ============================================================
# FRONTEND (frontend/.env) — Vite reads these at build time.
# These belong in frontend/.env, shown here for completeness.
# ============================================================
# VITE_API_BASE_URL=http://localhost:8000
# VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
